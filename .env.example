# ============================================================
# VARIABLES DE ENTORNO — TIENDA VIRTUAL MONGODB
# Copiar este archivo como .env y completar los valores
# NUNCA subir el archivo .env a control de versiones
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Base de datos MongoDB ---
# Formato local:   mongodb://localhost:27017/tienda_virtual
# Formato Atlas:   mongodb+srv://usuario:password@cluster.mongodb.net/tienda_virtual
MONGODB_URI=mongodb://localhost:27017/tienda_virtual

# Nombre de la base de datos (usado en logs)
DB_NAME=tienda_virtual

# --- Seguridad ---
# Clave secreta para firmar JWT (mínimo 32 caracteres)
JWT_SECRET=cambia_esta_clave_por_una_muy_segura_en_produccion
JWT_EXPIRES_IN=7d

# --- CORS ---
# Origen permitido para peticiones del frontend
# En desarrollo: http://localhost:5173 (Vite) o http://localhost:3001
CLIENT_URL=http://localhost:3001

# --- Paginación por defecto ---
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100
